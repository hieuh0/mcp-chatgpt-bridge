OPENAI_API_KEY=sk-your-key-here
# Optional, defaults to gpt-5
OPENAI_MODEL=gpt-5
# Optional. Auto-set to https://openrouter.ai/api/v1 when OPENAI_API_KEY starts
# with "sk-or-" (OpenRouter key format). Set explicitly to use another provider.
OPENAI_BASE_URL=

# Optional — every ask_chatgpt call also pushes Q&A here if set. Skipped silently if unset.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SLACK_WEBHOOK_URL=
